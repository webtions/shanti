{
	"version": 3,
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"title": "Clay",
	"slug": "clay",
	"description": "Warm clay palette with terracotta accent",
	"settings": {
		"color": {
			"palette": [
				{
					"slug": "base",
					"color": "#FFFCFA",
					"name": "Base"
				},
				{
					"slug": "contrast",
					"color": "#2c2420",
					"name": "Contrast"
				},
				{
					"slug": "contrast-alt",
					"color": "#5c534d",
					"name": "Contrast Alt"
				},
				{
					"slug": "primary",
					"color": "#D8A48F",
					"name": "Primary"
				},
				{
					"slug": "secondary",
					"color": "#F6EAE4",
					"name": "Secondary"
				},
				{
					"slug": "tertiary",
					"color": "#E6D6CF",
					"name": "Tertiary"
				}
			],
			"gradients": [
				{
					"slug": "base-to-secondary",
					"gradient": "linear-gradient(160deg, var(--wp--preset--color--base), var(--wp--preset--color--secondary))",
					"name": "Base to Secondary"
				},
				{
					"slug": "secondary-to-base",
					"gradient": "linear-gradient(160deg, var(--wp--preset--color--secondary), var(--wp--preset--color--base))",
					"name": "Secondary to Base"
				},
				{
					"slug": "primary-glow",
					"gradient": "radial-gradient(circle at center, color-mix(in srgb, var(--wp--preset--color--primary) 15%, transparent) 0%, transparent 70%)",
					"name": "Primary Glow"
				},
				{
					"slug": "primary-to-secondary",
					"gradient": "linear-gradient(135deg, var(--wp--preset--color--primary) 0%, var(--wp--preset--color--secondary) 100%)",
					"name": "Primary to Secondary"
				},
				{
					"slug": "base-to-tertiary",
					"gradient": "linear-gradient(to top, var(--wp--preset--color--tertiary) 0%, var(--wp--preset--color--base) 100%)",
					"name": "Base to Tertiary"
				}
			],
			"duotone": [
				{
					"colors": ["#2c2420", "#D8A48F"],
					"slug": "contrast-primary",
					"name": "Contrast and Primary"
				},
				{
					"colors": ["#5c534d", "#FFFCFA"],
					"slug": "dark-grayscale",
					"name": "Contrast Alt and Base"
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "var:preset|color|base",
			"text": "var:preset|color|contrast"
		}
	}
}
